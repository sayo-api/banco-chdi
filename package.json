{
  "name": "chdi-system-full",
  "version": "1.0.0",
  "description": "Sistema CHDI com Controle de Acesso por Página",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "build": "npm install && npm install --prefix client && npm run build --prefix client",
    "dev": "concurrently \"nodemon server/server.js\" \"npm run dev --prefix client\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": "18.x"
  }
}
